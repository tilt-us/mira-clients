{
  "name": "mira-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "MIRA_CLIENT_CONFIG=$PWD/mira-client.prod.toml tauri dev --config src-tauri/tauri.desktop-dev.conf.json",
    "local:desktop": "MIRA_CLIENT_CONFIG=$PWD/mira-client.toml tauri dev --config src-tauri/tauri.desktop-dev.conf.json",
    "prod:desktop": "tauri build --bundles deb --ci",
    "build:game-client": "cargo build -p mira-game-client",
    "generate:api": "node scripts/merge-openapi.mjs && openapi-ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fluent/bundle": "^0.19.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.16"
  }
}
