{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mira Installer",
  "version": "0.1.0",
  "identifier": "dev.mira.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mira Installer",
        "width": 450,
        "height": 575,
        "minWidth": 450,
        "minHeight": 575,
        "maxWidth": 450,
        "maxHeight": 575,
        "decorations": false,
        "maximizable": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
